# Mastodon Credentials - DO NOT COMMIT TO VERSION CONTROL
# Copy this file to .env and fill in your details

# Your Mastodon instance URL (e.g., https://mastodon.social or https://infosec.exchange)
MASTODON_BASE_URL=

# Your personal access token (obtained via Preferences > Development > New Application)
# Required scope: write:statuses
MASTODON_ACCESS_TOKEN=

# Optional: Mastodon post visibility (public, unlisted, private, direct)
# Default is unlisted.
# MASTODON_VISIBILITY=unlisted

# Optional: Ollama configuration (defaults to http://localhost:11434)
# OLLAMA_HOST=

# Optional: Disable automatic clipboard copying (set to true or 1)
# DISABLE_CLIPBOARD=
